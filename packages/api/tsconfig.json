{
    "compilerOptions": {
        "types": ["node"],
        "declaration": true,
        "outDir": "./dist",
        "rootDir": "./src",
        "importHelpers": true,
        "module": "commonjs",
        "strict": true,
        "target": "ES2021",
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "noUnusedParameters": false,
        "useDefineForClassFields": false,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true,
        "experimentalDecorators": true,
        "sourceMap": true,
        "plugins": [
            {
                "transform": "@boostercloud/metadata-booster"
            }
        ],
        "paths": {
            "@/*": ["./*"]
        },
        "skipLibCheck": true,
        "baseUrl": "./"
    },
    "include": ["booster.d.ts", "src/**/*"]
}
