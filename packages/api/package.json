{
    "name": "@package-name/api",
    "version": "0.1.0",
    "license": "PRIVATE",
    "scripts": {
        "docker-build": "docker buildx build -t ${0} --platform linux/amd64 --progress plain -f Dockerfile ../../",
        "build": "yarn clean && tsc -b tsconfig.json",
        "clean": "rimraf ./dist",
        "dev": "dotenv -c -- ksm exec -- nodemon --watch ./src --exec \"boost start -e default -p 4000\"",
        "dev-e2e": "dotenv -c ${NODE_ENV:-e2e} -- ksm exec -- nodemon --watch ./src --exec \"boost start -e default -p 4000\"",
        "start": "dotenv -c ${NODE_ENV:-local} -- node ./dist/index.js",
        "start-e2e": "nyc dotenv -c ${NODE_ENV:-e2e} -- node ./dist/index.js",
        "start-local": "dotenv -c ${NODE_ENV:-local} -- ksm exec -- node ./dist/index.js",
        "generate-domain": "graphql-codegen",
        "ts-patch": "ts-patch install -s"
    },
    "dependencies": {
        "@aws-sdk/client-cognito-identity-provider": "3.857.0",
        "@aws-sdk/client-geo-places": "3.911.0",
        "@aws-sdk/client-s3": "3.857.0",
        "@aws-sdk/credential-provider-env": "3.857.0",
        "@aws-sdk/s3-request-presigner": "3.857.0",
        "@boostercloud/framework-common-helpers": "3.4.3",
        "@boostercloud/framework-core": "3.4.3",
        "@boostercloud/framework-types": "3.4.3",
        "@lemoncompanies/booster-framework-provider-micro": "3.4.3",
        "cron": "3.5.0",
        "date-fns": "4.1.0",
        "date-fns-tz": "3.2.0",
        "dotenv-cli": "^7.4.2",
        "graphql": "16.10.0",
        "lodash": "^4.17.21",
        "mime-types": "^3.0.1",
        "node-fetch": "3.3.2",
        "piscina": "^5.1.3",
        "rrule": "2.8.1",
        "tslib": "^2.7.0",
        "zod": "3.25.76"
    },
    "devDependencies": {
        "@boostercloud/cli": "3.4.3",
        "@boostercloud/metadata-booster": "3.4.3",
        "@graphql-codegen/cli": "5.0.3",
        "@istanbuljs/nyc-config-typescript": "^1.0.2",
        "@types/lodash": "^4.17.10",
        "@types/mime-types": "^3.0.1",
        "@types/node-fetch": "^2.6.11",
        "@types/source-map-support": "^0",
        "nodemon": "^3.1.7",
        "nyc": "17.1.0",
        "rimraf": "^6.0.1",
        "source-map-support": "^0.5.21",
        "ts-node-dev": "^2.0.0",
        "ts-patch": "3.3.0",
        "typescript": "5.7.3"
    }
}
