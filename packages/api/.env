# ======================== GENERAL ========================

BOOSTER_ENV="default"
AIKIDO_TOKEN=""
BOOSTER_HTTP_BODY_SIZE_LIMIT="1mb"
ENABLE_GRAPHQL_INTROSPECTION="true"

# ======================== Mongo ========================

DB_PROVIDER="mongodb" 
DB_URI="mongodb://localhost:27017/package-name"
DB_STRIP_APPLICATION_STACK_NAME="true"
DB_RESTRICT_COLLECTION_NAME_LENGTH="true"

# ======================== MSSQL ========================

#DB_PROVIDER="mssql" 
#DB_AUTH_TYPE="default"
#DB_HOST="localhost"
#DB_USER="sa"
#DB_AUTH_DOMAIN= # needed for NTLM authentication, leave commented for others
#DB_PASSWORD="yourStrong!Password"
#DB_DATABASE="booster_template"
#DB_PORT=1433


# ======================== AWS ========================

OVERWRITE_AWS_CREDENTIALS="true" # Only for local development
# AWS_ACCESS_KEY_ID="keeper://AWS credentials/field/login"
# AWS_SECRET_ACCESS_KEY="keeper://AWS credentials/field/password"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-1"

# ======================== AUTH ========================

AWS_COGNITO_USER_POOL_ID="eu-west-1_taJU5gRhV"

JWKS_ISSUER="https://cognito-idp.eu-west-1.amazonaws.com/eu-west-1_taJU5gRhV"
JWKS_URI="https://cognito-idp.eu-west-1.amazonaws.com/eu-west-1_taJU5gRhV/.well-known/jwks.json"

# ======================== CRON ========================

CRON_TIME_EXAMPLE="0 0 7 * * *"
CRON_DISABLE_EXAMPLE="true"

# ======================== EMAIL ========================

EMAIL_API_KEY="your-sendgrid-api-key"
MOCK_EMAIL="true"

# ======================== STORAGE ========================

MOCK_S3="true"
# MOCK_AWS_S3_ENDPOINT="http://localhost:1080/mocked-s3" # Very basic mock server for S3
MOCK_AWS_S3_ENDPOINT="http://s3.localhost.localstack.cloud:4566/" # Full fledged localstack S3 mock
S3_STORAGE_BUCKET="local-bucket"

# ======================== LOCATION ========================

PLACES_API_KEY=""
