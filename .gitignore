# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# yarn (see https://yarnpkg.com/getting-started/qa#which-files-should-be-gitignored)
.yarn/*
!.yarn/releases
!.yarn/patches
!.yarn/plugins
!.yarn/sdks
!.yarn/versions

# dependencies
/node_modules

# testing
**/coverage/**
**/.nyc_output/**

# next.js
/.next/
/out/

# production
/build
dist
tsconfig.tsbuildinfo

# misc
.DS_Store
*.pem
.github/copilot-instructions.md

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

.idea/

# bruno api calls
.bruno/
