{
    "name": "package-name",
    "version": "0.1.0",
    "private": true,
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "yarn workspace @package-name/${0} build",
        "start": "yarn workspace @package-name/${0} start",
        "start-e2e": "yarn workspace @package-name/${0} start-e2e",
        "dev": "yarn workspace @package-name/${0} dev",
        "dev-e2e": "yarn workspace @package-name/${0} dev-e2e",
        "test-web": "yarn workspace @package-name/e2e-web test",
        "test-api": "yarn workspace @package-name/e2e-api test",
        "generate-domain": "yarn workspace @package-name/web graphql-codegen",
        "postinstall": "is-ci || husky install",
        "format": "prettier --write .",
        "lint": "eslint --fix .",
        "generate-disclaimer": "yarn licenses generate-disclaimer --recursive --production > packages/api/disclaimer.txt",
        "check-licenses": "./audit.sh",
        "prepare": "husky install",
        "start_local_env": "bash ./packages/external_services/start_local_environment.sh",
        "stop_local_env": "bash ./packages/external_services/stop_local_environment.sh",
        "remove_local_volumes": "bash ./packages/external_services/stop_local_environment_remove_volumes.sh -v"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.5.0",
        "@commitlint/config-conventional": "^19.5.0",
        "@types/node": "22.10.10",
        "@typescript-eslint/eslint-plugin": "7.18.0",
        "@typescript-eslint/parser": "7.18.0",
        "eslint": "8.57.1",
        "eslint-config-prettier": "9.1.0",
        "eslint-plugin-import": "2.31.0",
        "eslint-plugin-jsx-a11y": "6.10.0",
        "eslint-plugin-react": "7.37.1",
        "eslint-plugin-react-hooks": "4.6.2",
        "eslint-plugin-simple-import-sort": "12.1.1",
        "eslint-plugin-unused-imports": "3.2.0",
        "husky": "^9.1.6",
        "is-ci": "3.0.1",
        "lint-staged": "15.2.10",
        "prettier": "3.3.3",
        "typescript": "5.7.3"
    },
    "packageManager": "yarn@4.7.0"
}
